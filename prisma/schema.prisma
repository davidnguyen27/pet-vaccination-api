  @@index([is_read])
  @@index([scheduled_at])
  @@index([sent_at])
  @@map("notification")
}

model WorkingShift {
  id               String    @id @default(uuid()) @map("_id") @db.Uuid
  vet_id           String    @map("vet_id") @db.Uuid
  day_of_week      weekday   @map("day_of_week")
  start_time       DateTime  @map("start_time") @db.Time
  end_time         DateTime  @map("end_time") @db.Time
  slot_duration    Int       @default(30) @map("slot_duration") // in minutes
  max_appointments Int       @default(1) @map("max_appointments")
  notes            String?   @db.VarChar(255)
  is_deleted       Boolean   @default(false) @map("is_deleted")
  created_at       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted_at       DateTime? @map("deleted_at") @db.Timestamptz(6)

  vet               Vet               @relation(fields: [vet_id], references: [id])
  appointment_slots AppointmentSlot[]

  @@index([vet_id])
  @@index([vet_id, day_of_week])
  @@index([is_deleted])
  @@map("working_shift")
}

model AppointmentSlot {
  id               String    @id @default(uuid()) @map("_id") @db.Uuid
  shift_id         String    @map("shift_id") @db.Uuid
  slot_date        DateTime  @map("slot_date") @db.Date
  start_time       DateTime  @map("start_time") @db.Time
  end_time         DateTime  @map("end_time") @db.Time
  booked_count     Int       @default(0) @map("booked_count")
  max_appointments Int       @map("max_appointments")
  is_deleted       Boolean   @default(false) @map("is_deleted")
  created_at       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted_at       DateTime? @map("deleted_at") @db.Timestamptz(6)

  shift        WorkingShift  @relation(fields: [shift_id], references: [id])
  appointments Appointment[]

  @@unique([shift_id, slot_date, start_time])
  @@index([slot_date])
  @@index([is_deleted])
  @@map("appointment_slot")
}

model BlockTime {
  id         String     @id @default(uuid()) @map("_id") @db.Uuid
  vet_id     String     @map("vet_id") @db.Uuid
  type       block_type @default(TIME_OFF) @map("type")
  start_at   DateTime   @map("start_at") @db.Timestamptz(6)
  end_at     DateTime   @map("end_at") @db.Timestamptz(6)
  reason     String?    @map("reason") @db.VarChar(255)
  is_deleted Boolean    @default(false) @map("is_deleted")
  created_at DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted_at DateTime?  @map("deleted_at") @db.Timestamptz(6)

  vet Vet @relation(fields: [vet_id], references: [id])

  @@index([vet_id])
  @@index([start_at])
  @@index([end_at])
  @@index([is_deleted])
  @@map("block_time")
}

model ServicePrice {
