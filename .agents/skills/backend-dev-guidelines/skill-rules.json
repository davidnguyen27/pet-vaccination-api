{
  "skills": {
    "backend-dev-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "promptTriggers": {
        "keywords": [
          "express",
          "node",
          "nodejs",
          "backend",
          "api",
          "route",
          "controller",
          "service",
          "repository",
          "prisma",
          "class-validator",
          "class-transformer",
          "dto",
          "validation",
          "middleware",
          "auth",
          "jwt",
          "refresh token",
          "access token",
          "microchip",
          "vaccination",
          "appointment"
        ],
        "intentPatterns": [
          "create.*api",
          "create.*route",
          "add.*endpoint",
          "fix.*controller",
          "refactor.*service",
          "setup.*prisma",
          "handle.*auth",
          "implement.*refresh.*token",
          "validate.*request",
          "build.*module",
          "thiết kế.*api",
          "tạo.*api",
          "tạo.*route",
          "sửa.*controller",
          "sửa.*service",
          "setup.*prisma",
          "xử lý.*auth",
