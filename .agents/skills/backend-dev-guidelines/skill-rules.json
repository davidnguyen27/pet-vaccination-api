        "contentPatterns": [
          "express",
          "Router",
          "Request",
          "Response",
          "NextFunction",
          "PrismaClient",
          "@prisma/client",
          "class-validator",
          "class-transformer",
          "validateBody",
          "validateQuery",
          "validateParams",
          "Dto",
          "jwt",
          "bcrypt",
          "cookie"
        ]
      }
    }
  }
}
